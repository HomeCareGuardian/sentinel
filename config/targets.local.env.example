# Pi hub on LAN — set HUB_HOST (device id; .local is added automatically)
E2E_TARGET=local
E2E_TARGET_LABEL="Sentinel local (Pi LAN)"

# e.g. curl http://hcg-hub-5fcf7e73cfe7a329.local:8080/api/devices
HUB_HOST=hcg-hub-5fcf7e73cfe7a329
HUB_PORT=8080

# Or set a full URL instead (HUB_HOST omitted):
# HUB_BASE_URL=http://hcg-hub-5fcf7e73cfe7a329.local:8080

# Hubs past setup mode refuse production API routes from direct LAN callers
# (hcg#640/#2333). Sentinel auto-detects this and reruns requests as
# `ssh pi@$PI_HOST curl http://127.0.0.1:8080/...` (SSH exec; -L tunnels are
# disabled by hub sshd hardening). PI_HOST is derived from HUB_HOST, or set it
# explicitly. HUB_TRANSPORT=auto|direct|ssh-exec overrides detection.
# PI_HOST=192.168.2.68
# HUB_SSH_USER=pi
# HUB_TRANSPORT=auto

WEBSITE_BASE_URL=http://127.0.0.1:3000
# Optional: relay-path iOS checks (suites/ios/run_relay_e2e.py). Leave unset to
# skip; point at staging for the full relay login → hubs → proxy flow.
# RELAY_BASE_URL=https://staging-relay.homecareguardian.io

# Required for J4 acknowledge — copy from Pi ~/hcg-core/.env (run-local.sh validates)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

E2E_USER_EMAIL=e2e-caregiver@homecareguardian.test
E2E_USER_PASSWORD=ChangeMeE2e123!
E2E_USER_NAME="E2E Caregiver"

E2E_MOTION_ENTITY_ID=

E2E_HUB_READY_TIMEOUT=120
E2E_WEBSITE_READY_TIMEOUT=60
