# Optional overrides applied on top of the active profile (local or gcp).
# Copy to config/targets.env only if you need secrets or URL overrides.
#
# Prefer profile files:
#   config/targets.local.env   — loopback hub + local Next dev server
#   config/targets.gcp.env     — GCP E2E VM + staging website
#
# Select profile when running tests:
#   ./bin/sentinel --local pr-gate
#   ./bin/sentinel --gcp pr-gate
#   E2E_TARGET=gcp ./bin/sentinel pr-gate

# E2E_TARGET=local
