# GCP staging targets — copy to config/targets.gcp.env (gitignored)
E2E_TARGET=gcp
E2E_TARGET_LABEL="GCP E2E hub"

# Hub: GCE VM running hcg-core compose (see infra/gcp/README.md)
HUB_BASE_URL=https://e2e-hub.example.com:8080
# Website: staging deploy (Workers, preview, or Cloud Run)
WEBSITE_BASE_URL=https://staging.homecareguardian.io

ADMIN_USERNAME=e2e_admin
ADMIN_PASSWORD=change_me

E2E_USER_EMAIL=e2e-caregiver-gcp@homecareguardian.test
E2E_USER_PASSWORD=ChangeMeE2eGcp123!
E2E_USER_NAME="E2E Caregiver GCP"

# Set when your GCP hub bootstrap exposes a known HA entity
E2E_MOTION_ENTITY_ID=

# GCP cold start / HA first boot may take longer
E2E_HUB_READY_TIMEOUT=900
E2E_WEBSITE_READY_TIMEOUT=180
