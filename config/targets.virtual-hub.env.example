# Virtual Customer Hub target — copy to targets.virtual-hub.env (gitignored).
E2E_TARGET=virtual-hub
E2E_TARGET_LABEL="Sentinel virtual customer hub"

# Hub under test (published image pin; align with hcg OTA when multi-image OTA lands)
HCG_IMAGE=ghcr.io/homecareguardian/hcg-core:latest
HOME_ASSISTANT_VERSION=2026.6.4
# HOME_ASSISTANT_IMAGE=
POSTGRES_IMAGE=docker.io/library/postgres:15

HUB_PUBLISH_HOST=127.0.0.1
HUB_PORT=8080
HUB_BASE_URL=http://127.0.0.1:8080

# Hub admin Basic auth (must match compose ADMIN_*)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=vch_admin_change_me

# HA long-lived token — filled by ./scripts/virtual-hub.sh bootstrap-ha
HA_TOKEN=

# Twin DB passwords (test-only; not production secrets)
POSTGRES_PASSWORD=vch_postgres_password
HA_DB_PASSWORD=vch_readonly_password
HCG_DB_PASSWORD=vch_hcg_password

# Simulator defaults
VCH_SCENARIO=idle_home
VCH_ACCELERATED=0
VCH_LOOP_DAYS=1

E2E_HUB_READY_TIMEOUT=180
E2E_MOTION_ENTITY_ID=binary_sensor.vch_kitchen_motion
